# CI-bygge (delade Tekton-pipelinen): kopieras till .env.local i Dockerfile så att
# bygget bakar in PLATSHÅLLARE i .next-outputen. entrypoint.sh ersätter dem med
# riktiga miljövärden vid containerstart (samma image för alla miljöer).
#
# Platshållaren är URL-formad (next.config.js rewrites kräver giltig URL vid bygge)
# och GEMEN med bindestreck — Next/URL-parsern normaliserar hostnamn till gemener,
# så en versal platshållare skulle inte gå att hitta i den byggda outputen.
BACKEND_INTERNAL_URL=http://backend-internal-url-placeholder
