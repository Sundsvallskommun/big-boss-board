# Big Boss Board (bbb) — miljövariabler.
# Kopiera till .env för lokal körning. Riktiga värden läggs i Dokploy, aldrig i repo.

# --- Postgres ---
POSTGRES_USER=bbb
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=bbb

# --- Backend ---
# Async-driver (asyncpg) mot db-tjänsten på compose-nätverket.
DATABASE_URL=postgresql+asyncpg://bbb:change-me-locally@db:5432/bbb

# HME-data versionshanteras INTE (riktiga, anonymiserade siffror) och levereras utanför git.
# Två vägar in:
#  1) Import-endpoint (rekommenderas i drift): sätt IMPORT_TOKEN och kör
#     `IMPORT_TOKEN=... python3 scripts/import_hme.py --url <bas-url>`.
#  2) Fil vid uppstart (bootstrap/lokalt): lägg HME_totalindex.json i en katalog och peka
#     HME_DATA_DIR dit (bind-monteras till backend; seed läser den).
HME_DATA_DIR=

# Hemlig nyckel för dataimport-endpointen (/api/import/hme). Tom = endpoint avstängd.
# Läggs bara i Dokploy/lokal .env — aldrig i repo. Skild från ACCESS_CODE.
IMPORT_TOKEN=

# --- Frontend ---
# Intern URL som Next.js använder för server-side rewrites av /api/* -> backend.
BACKEND_INTERNAL_URL=http://backend:8000
NODE_ENV=production
PORT=3000
# Host-port för lokal körning (docker-compose.override.yml). Ändra vid portkrock.
# Används inte i Dokploy (där Traefik routar mot port 3000).
FRONTEND_PORT=3000

# --- Login (stub i v1) ---
# Sätt ett värde för att kräva åtkomstkod. Tom kod är bara tillåten om
# ALLOW_OPEN_ACCESS=true sätts uttryckligen (lokalt/demo, aldrig drift).
# Används av både backend och frontend (frontend gatar UI:t server-side).
ACCESS_CODE=
ALLOW_OPEN_ACCESS=false

# Separat admin-kod. Logga in med denna (i stället för ACCESS_CODE) för att se
# import-GUI:t på /admin/import. Tom = inget admin-läge. Vanliga ACCESS_CODE ser inte GUI:t.
ADMIN_ACCESSCODE=

# --- Auth-läge ---
# access_code = stubben ovan (default, lokal/tidig drift). saml = kommunens IdP via
# backend-ägt SAML-flöde (backend/app/auth/ — login, callback, metadata, logout, /api/me).
AUTH_MODE=access_code

# --- Sessioner (krävs i saml-läget) ---
# Server-side sessioner i Redis (session-id i httpOnly-cookie). Samma namnkontrakt som
# draken/OpenShift-manifesten. Lokalt utan Redis används in-memory-fallback; är
# REDIS_HOST satt men Redis onåbar vägrar backend starta (ingen tyst fallback i prod).
SECRET_KEY=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- SAML SP <-> kommunens IdP ---
# Certifikat och nycklar är PEM-innehåll och läggs ALDRIG i repo — i prod via OpenShift
# Secrets (test-saml-keys/backend-secrets-mönstret), lokalt via fake-IdP:n
# (web-app-fake-sso-idp) i docker-compose.override.yml.
SAML_ISSUER=
SAML_ENTRY_SSO=
# IdP:ns entityID i den syntetiserade metadatan. Tom = SAML_ENTRY_SSO räcker
# (passport-saml-mönstret: bara entryPoint konfigureras).
SAML_IDP_ENTITY_ID=
# Tillåten klockdrift mot IdP i sekunder (draken stänger av kontrollen helt; vi
# validerar men tolererar drift — höj om IdP:ns klocka glider).
SAML_CLOCK_SKEW=300
# Strikt SAML-validering (destination/audience/recipient). Ska vara true i drift.
# Sätt false endast mot en kontrollerad test-IdP som skickar fel audience/Recipient.
SAML_STRICT=true
# Signaturkrav för inkommande SAML. Prod bör normalt kräva signerad assertion.
SAML_WANT_ASSERTIONS_SIGNED=true
SAML_WANT_MESSAGES_SIGNED=false
# Avvisa föråldrade signaturalgoritmer (sha1). Ska vara true i drift.
# Test-IdP:n (fake-sso-idp) signerar rsa-sha1/sha1 → sätt false endast mot den.
SAML_REJECT_DEPRECATED_ALG=true
SAML_CALLBACK_URL=
SAML_LOGOUT_CALLBACK_URL=
SAML_SUCCESS_REDIRECT=
SAML_FAILURE_REDIRECT=
SAML_IDP_PUBLIC_CERT=
SAML_PUBLIC_KEY=
SAML_PRIVATE_KEY=
# IdP:ns utloggnings-URL ("Logga ut" i avatar-menyn rensar även IdP-sessionen via
# <url>?RelayState=<retur-URL>). Test-IdP:n: http://172.16.124.2/logout — den hanterar
# inte riktiga SAML SLO-requests. Tom = endast lokal utloggning (nästa login SSO:ar).
SAML_IDP_LOGOUT_URL=

# Gruppstyrning: kommaseparerade AD-grupper. ALLOWED = får logga in,
# ADMIN = ser adminvyer (ersätter ADMIN_ACCESSCODE i saml-läget).
SAML_ALLOWED_GROUPS=
SAML_ADMIN_GROUPS=

# --- WSO2 / api.sundsvall.se (maskin-till-maskin, OAuth2 client credentials) ---
# Används först när bbb anropar centrala API:er. Token hämtas från gatewayns
# token-endpoint och cachas i Redis (delas mellan poddar). Skilt från SAML-login.
API_BASE_URL=https://api-test.sundsvall.se
CLIENT_KEY=
CLIENT_SECRET=
