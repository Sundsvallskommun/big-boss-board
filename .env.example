# Big Boss Board (bbb) — miljövariabler.
# Kopiera till .env för lokal körning. Riktiga värden läggs i Dokploy, aldrig i repo.

# --- Postgres ---
POSTGRES_USER=bbb
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=bbb

# --- Backend ---
# Async-driver (asyncpg) mot db-tjänsten på compose-nätverket.
DATABASE_URL=postgresql+asyncpg://bbb:change-me-locally@db:5432/bbb

# HME-aggregatet (backend/app/data/hme_2025.json) versionshanteras INTE — det
# innehåller riktiga (anonymiserade) siffror och levereras utanför git.
# Lokalt: lämna tomt → ./backend/app/data monteras (där genererad fil ligger).
# Dokploy: peka mot en värdkatalog dit hme_2025.json laddats upp.
# Generera filen med: python3 scripts/build_hme_aggregate.py
HME_DATA_DIR=

# --- Frontend ---
# Intern URL som Next.js använder för server-side rewrites av /api/* -> backend.
BACKEND_INTERNAL_URL=http://backend:8000
NODE_ENV=production
PORT=3000
# Host-port för lokal körning (docker-compose.override.yml). Ändra vid portkrock.
# Används inte i Dokploy (där Traefik routar mot port 3000).
FRONTEND_PORT=3000

# --- Login (stub i v1) ---
# Tom = öppen tjänst (ingen inloggning). Sätt ett värde för att kräva åtkomstkod.
# Används av både backend och frontend (frontend gatar UI:t server-side).
ACCESS_CODE=
